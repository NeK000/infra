COMPOSE_PROJECT_NAME={{ compose_stack_project_name }}
TIMEZONE={{ timezone }}

TRAEFIK_OWN_DOMAIN={{ local_traefik_domain }}
TRAEFIK_CONFIG_SHA={{ lookup('file', compose_stack_local_files_dir ~ '/traefik/traefik.yml') | hash('sha256') }}

LOCAL_HOMEPAGE_DOMAIN={{ LOCAL_HOMEPAGE_DOMAIN }}
HOMEPAGE_CONFIG_SHA={{ (
  lookup('template', compose_stack_local_templates_dir ~ '/homepage/config/docker.yaml.j2')
  ~ lookup('file', compose_stack_local_files_dir ~ '/homepage/config/settings.yaml')
  ~ lookup('file', compose_stack_local_files_dir ~ '/homepage/config/services.yaml')
  ~ lookup('file', compose_stack_local_files_dir ~ '/homepage/config/bookmarks.yaml')
  ~ lookup('file', compose_stack_local_files_dir ~ '/homepage/config/widgets.yaml')
) | hash('sha256') }}

TSDPROXY_CONFIG_SHA={{ lookup('template', compose_stack_local_templates_dir ~ '/tsdproxy/config/tsdproxy.yaml.j2') | hash('sha256') }}
TSDPROXY_AUTHKEY_SHA={{ EDGE_TAILSCALE_AUTHKEY | hash('sha256') }}
