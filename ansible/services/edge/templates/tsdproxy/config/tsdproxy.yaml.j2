---
defaultProxyProvider: default

docker:
  edge-local:
    host: "tcp://edge-socket-proxy:2375"
    targetHostname: "{{ ansible_default_ipv4.address | default(ansible_host | default(inventory_hostname)) }}"
    defaultProxyProvider: default
{% for docker_host in docker_hosts %}
  {{ docker_host.name }}:
    host: "tcp://{{ docker_host.host }}:{{ docker_host.port }}"
    targetHostname: "{{ docker_host.target_hostname }}"
    defaultProxyProvider: default
{% endfor %}

tailscale:
  providers:
    default:
      authKeyFile: /run/secrets/tailscale_authkey
  dataDir: /data

http:
  hostname: 0.0.0.0
  port: 8080

files: {}

log:
  level: info
  json: false

proxyAccessLog: true
